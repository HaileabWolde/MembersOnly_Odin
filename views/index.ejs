<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">  
    <title>MembersOnly</title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body class="min-h-screen bg-gradient-to-br from-gray-900 to-gray-800 text-white p-8">

    <div class="max-w-4xl mx-auto">
        <%- include('header', {user: locals.user}) %>

        <div class="max-w-2xl mx-auto mt-20">
            <% if (posts && posts.length > 0) { %>
                <% posts.forEach((post) => { %>
                    <div class="w-full bg-white/10 border border-white/20 hover:border-white/40 
                                rounded-3xl px-8 py-7 mb-6 text-white flex flex-col gap-5 
                                transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-black/30 backdrop-blur-md">
                        
                        <h1 class="font-bold text-3xl leading-tight"><%= post.post_title || 'Anonymous' %></h1>
                        
                        <div class="flex gap-4 text-sm">
                            <div class="bg-white/10 border border-white/20 px-5 py-2.5 rounded-2xl flex items-center gap-3">
                                <% if(user){ %>
                                    <i class="fa-solid fa-user text-amber-400"></i>
                                    <p><%= post.author_name %></p>
                                <% } else { %>
                                    <i class="fa-solid fa-user-secret"></i>
                                    <p>????</p>
                                <% } %>
                            </div>
                            
                            <div class="bg-white/10 border border-white/20 px-5 py-2.5 rounded-2xl flex items-center gap-3">
                                <% if(user){ %>
                                    <i class="fa-solid fa-clock text-amber-400"></i>
                                    <p><%= dayjs(post.post_created).format('MMM D, h:mm A') %></p>
                                <% } else { %>
                                    <i class="fa-solid fa-clock"></i>
                                    <p>????</p>
                                <% } %>
                            </div>
                        </div>
                        
                        <p class="font-semibold leading-relaxed text-lg text-white/90">
                            <%= post.post_content %>
                        </p>
                    </div>
                <% }); %>
            <% } else { %>
                <p class="text-gray-400 text-center">No posts yet.</p>
            <% } %>
        </div>
    </div>
</body>
</html>